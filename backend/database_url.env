# database_url.env
# This file contains the database connection URL for the Wetlands-prototype-MVP project.
# Replace 'username', 'password', and 'database_name' with your actual PostgreSQL credentials.

DATABASE_URL=postgresql://postgres:MurgZer0709*@localhost:5432/postgres 

dbname="postgresql",  # database name
user="postgres",  # database username
password="MurgZer0709*",  # database password
host="localhost",  # database host - 'localhost' for local development, or the hostname/IP of your database server
port="5432"  # database port with 4 digits (default for PostgreSQL) as string